<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/vc_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/space_xl">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="← Courses"
            android:textColor="@color/vc_blue"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            style="@style/VercelMonoLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_xl"
            android:text="COURSE / CSE101" />

        <TextView
            android:id="@+id/textCourseName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_md"
            android:textColor="@color/vc_ink"
            android:textSize="38sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textCourseMeta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_sm"
            android:textColor="@color/vc_body"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="78dp"
            android:layout_marginTop="@dimen/space_lg"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/bg_card"
                android:gravity="center"
                android:text="LOCATION\nA-301"
                android:textColor="@color/vc_ink"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="@dimen/space_sm"
                android:layout_weight="1"
                android:background="@drawable/bg_card"
                android:gravity="center"
                android:text="SEMESTER\n2025-2"
                android:textColor="@color/vc_ink"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_lg"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="@dimen/space_xl">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/textTaskTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/vc_ink"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/textTaskStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_status_success"
                    android:fontFamily="monospace"
                    android:paddingStart="@dimen/space_md"
                    android:paddingTop="@dimen/space_xs"
                    android:paddingEnd="@dimen/space_md"
                    android:paddingBottom="@dimen/space_xs"
                    android:textColor="@color/vc_blue"
                    android:textSize="12sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/textTaskTime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_xl"
                android:textColor="@color/vc_body"
                android:textSize="15sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_lg"
                android:background="@drawable/bg_inset_vercel"
                android:padding="@dimen/space_lg"
                android:text="RULE\n有效时间内提交为已签到，超时提交为迟到。"
                android:textColor="@color/vc_body"
                android:textSize="13sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonCheckIn"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:layout_marginTop="@dimen/space_lg"
                android:text="输入口令签到"
                android:textColor="@color/vc_card"
                app:backgroundTint="@color/vc_ink"
                app:cornerRadius="999dp" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
