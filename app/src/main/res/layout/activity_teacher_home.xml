<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/vc_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/space_xl">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_lg"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                style="@style/VercelMonoLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="TEACHER DASHBOARD" />

            <TextView
                android:id="@+id/buttonProfile"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_avatar_button"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="我"
                android:textColor="@color/vc_card"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/textGreeting"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_sm"
            android:textColor="@color/vc_ink"
            android:textSize="34sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textSummary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_sm"
            android:textColor="@color/vc_body"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_lg"
            android:background="@drawable/bg_navy_card"
            android:orientation="vertical"
            android:padding="@dimen/space_xl">

            <TextView
                style="@style/VercelMonoLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="ACTION" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_lg"
                android:text="发起新的口令签到"
                android:textColor="@color/vc_card"
                android:textSize="23sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_md"
                android:text="创建后可查看状态，也可以手动截止正在进行的签到。"
                android:textColor="@color/vc_mute"
                android:textSize="13sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonCreateTask"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="@dimen/space_lg"
                android:text="发起签到"
                android:textColor="@color/vc_ink"
                app:backgroundTint="@color/vc_card"
                app:cornerRadius="999dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/textHomeStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_md"
            android:textColor="@color/vc_body"
            android:textSize="13sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_lg"
            android:text="Recent tasks"
            android:textColor="@color/vc_ink"
            android:textSize="20sp"
            android:textStyle="bold" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerTasks"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_md"
            android:nestedScrollingEnabled="false" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_lg"
            android:text="Courses"
            android:textColor="@color/vc_ink"
            android:textSize="20sp"
            android:textStyle="bold" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerCourses"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_md"
            android:nestedScrollingEnabled="false" />
    </LinearLayout>
</ScrollView>
