<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/notion_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/space_xl">

        <TextView
            android:id="@+id/buttonBack"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="← Tasks"
            android:textColor="@color/notion_purple"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            style="@style/NotionLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_xl"
            android:text="CHECK-IN DETAIL" />

        <TextView
            android:id="@+id/textTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_sm"
            android:textColor="@color/notion_ink"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textMeta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_sm"
            android:textColor="@color/notion_body"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/textStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_md"
            android:fontFamily="monospace"
            android:textColor="@color/notion_purple"
            android:textSize="13sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_lg"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonRefresh"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="刷新"
                android:textColor="@color/notion_ink"
                app:backgroundTint="@color/notion_card"
                app:cornerRadius="@dimen/radius_md"
                app:strokeColor="@color/notion_line"
                app:strokeWidth="1dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonEnd"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_marginStart="@dimen/space_sm"
                android:layout_weight="1"
                android:text="手动截止"
                android:textColor="@color/notion_card"
                app:backgroundTint="@color/cc_primary"
                app:cornerRadius="@dimen/radius_md" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutQrCode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_lg"
            android:background="@drawable/bg_card"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="@dimen/space_lg"
            android:visibility="gone">

            <TextView
                style="@style/NotionLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="QR CHECK-IN" />

            <ImageView
                android:id="@+id/imageQrCode"
                android:layout_width="220dp"
                android:layout_height="220dp"
                android:layout_marginTop="@dimen/space_md"
                android:contentDescription="签到二维码" />

            <TextView
                android:id="@+id/textQrPayload"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_md"
                android:gravity="center"
                android:textColor="@color/notion_body"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_lg"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="@dimen/space_lg">

            <TextView
                style="@style/NotionLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="LIVE SUMMARY" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_md"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/textTotal"
                    android:layout_width="0dp"
                    android:layout_height="72dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_card"
                    android:gravity="center"
                    android:textColor="@color/notion_ink"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/textSigned"
                    android:layout_width="0dp"
                    android:layout_height="72dp"
                    android:layout_marginStart="@dimen/space_sm"
                    android:layout_weight="1"
                    android:background="@drawable/bg_card"
                    android:gravity="center"
                    android:textColor="@color/notion_purple"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/textUnsigned"
                    android:layout_width="0dp"
                    android:layout_height="72dp"
                    android:layout_marginStart="@dimen/space_sm"
                    android:layout_weight="1"
                    android:background="@drawable/bg_card"
                    android:gravity="center"
                    android:textColor="@color/notion_mute"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_sm"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/textLate"
                    android:layout_width="0dp"
                    android:layout_height="72dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_card"
                    android:gravity="center"
                    android:textColor="@color/notion_warning"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/textAbsent"
                    android:layout_width="0dp"
                    android:layout_height="72dp"
                    android:layout_marginStart="@dimen/space_sm"
                    android:layout_weight="1"
                    android:background="@drawable/bg_card"
                    android:gravity="center"
                    android:textColor="@color/notion_error"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/textRate"
                    android:layout_width="0dp"
                    android:layout_height="72dp"
                    android:layout_marginStart="@dimen/space_sm"
                    android:layout_weight="1"
                    android:background="@drawable/bg_card"
                    android:gravity="center"
                    android:textColor="@color/notion_purple"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/textStudentsTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_lg"
            android:text="学生签到明细"
            android:textColor="@color/notion_ink"
            android:textSize="20sp"
            android:textStyle="bold" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerStudents"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_md"
            android:nestedScrollingEnabled="false" />
    </LinearLayout>
</ScrollView>
