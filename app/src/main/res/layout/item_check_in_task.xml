<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/space_md"
    android:background="@drawable/bg_card"
    android:orientation="vertical"
    android:padding="@dimen/space_lg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/textTaskTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/notion_ink"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textTaskStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textColor="@color/notion_purple"
            android:textSize="13sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/textTaskCourse"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_sm"
        android:textColor="@color/notion_body"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/textTaskTime"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_xs"
        android:fontFamily="monospace"
        android:textColor="@color/notion_mute"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/textTaskSummary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_sm"
        android:textColor="@color/notion_body"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/textTaskHint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_xs"
        android:fontFamily="monospace"
        android:text="点击查看学生签到明细"
        android:textColor="@color/notion_purple"
        android:textSize="12sp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/buttonEndTask"
        android:layout_width="match_parent"
        android:layout_height="42dp"
        android:layout_marginTop="@dimen/space_md"
        android:text="手动截止"
        android:textColor="@color/notion_card"
        app:backgroundTint="@color/cc_primary"
        app:cornerRadius="@dimen/radius_md" />
</LinearLayout>
