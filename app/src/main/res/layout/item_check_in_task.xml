<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/space_md"
    android:background="@drawable/bg_card"
    android:orientation="vertical"
    android:padding="@dimen/space_lg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/textTaskTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/vc_ink"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textTaskStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textColor="@color/vc_blue"
            android:textSize="13sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/textTaskCourse"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_sm"
        android:textColor="@color/vc_body"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/textTaskTime"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_xs"
        android:fontFamily="monospace"
        android:textColor="@color/vc_mute"
        android:textSize="12sp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/buttonEndTask"
        android:layout_width="match_parent"
        android:layout_height="42dp"
        android:layout_marginTop="@dimen/space_md"
        android:text="手动截止"
        android:textColor="@color/vc_card"
        app:backgroundTint="@color/vc_ink"
        app:cornerRadius="999dp" />
</LinearLayout>
