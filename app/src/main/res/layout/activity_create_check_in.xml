<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/notion_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/space_xl">

        <TextView
            android:id="@+id/textBack"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="← Teacher"
            android:textColor="@color/notion_purple"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            style="@style/NotionLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_xl"
            android:text="CREATE TASK" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_md"
            android:text="发起签到."
            android:textColor="@color/notion_ink"
            android:textSize="38sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_sm"
            android:text="选择课程并设置口令，提交后创建真实数据库任务。"
            android:textColor="@color/notion_body"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_lg"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="@dimen/space_xl">

            <TextView
                style="@style/NotionLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="COURSE" />

            <Spinner
                android:id="@+id/spinnerCourses"
                android:layout_width="match_parent"
                android:layout_height="@dimen/input_height"
                android:layout_marginTop="@dimen/space_sm"
                android:background="@drawable/bg_input_notion"
                android:paddingStart="@dimen/space_lg"
                android:paddingEnd="@dimen/space_lg" />

            <TextView
                style="@style/NotionLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_lg"
                android:text="TITLE" />

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editTitle"
                android:layout_width="match_parent"
                android:layout_height="@dimen/input_height"
                android:layout_marginTop="@dimen/space_sm"
                android:background="@drawable/bg_input_notion"
                android:paddingStart="@dimen/space_lg"
                android:paddingEnd="@dimen/space_lg"
                android:singleLine="true"
                android:textColor="@color/notion_ink" />

            <TextView
                style="@style/NotionLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_lg"
                android:text="CHECK-IN TYPE" />

            <Spinner
                android:id="@+id/spinnerCheckInType"
                android:layout_width="match_parent"
                android:layout_height="@dimen/input_height"
                android:layout_marginTop="@dimen/space_sm"
                android:background="@drawable/bg_input_notion"
                android:paddingStart="@dimen/space_lg"
                android:paddingEnd="@dimen/space_lg" />

            <TextView
                style="@style/NotionLabel"
                android:id="@+id/textPasswordLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_lg"
                android:text="CODE" />

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editPassword"
                android:layout_width="match_parent"
                android:layout_height="@dimen/input_height"
                android:layout_marginTop="@dimen/space_sm"
                android:background="@drawable/bg_input_notion"
                android:inputType="number"
                android:paddingStart="@dimen/space_lg"
                android:paddingEnd="@dimen/space_lg"
                android:singleLine="true"
                android:textColor="@color/notion_ink" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_lg"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        style="@style/NotionLabel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="START TIME" />

                    <TextView
                        android:id="@+id/editStartTime"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/input_height"
                        android:layout_marginTop="@dimen/space_sm"
                        android:background="@drawable/bg_inset_notion"
                        android:clickable="true"
                        android:focusable="true"
                        android:fontFamily="monospace"
                        android:gravity="center_vertical"
                        android:paddingStart="@dimen/space_md"
                        android:paddingEnd="@dimen/space_md"
                        android:textColor="@color/notion_ink"
                        android:textSize="12sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/space_sm"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        style="@style/NotionLabel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="END TIME" />

                    <TextView
                        android:id="@+id/editEndTime"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/input_height"
                        android:layout_marginTop="@dimen/space_sm"
                        android:background="@drawable/bg_inset_notion"
                        android:clickable="true"
                        android:focusable="true"
                        android:fontFamily="monospace"
                        android:gravity="center_vertical"
                        android:paddingStart="@dimen/space_md"
                        android:paddingEnd="@dimen/space_md"
                        android:textColor="@color/notion_ink"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonCreate"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:layout_marginTop="@dimen/space_lg"
                android:text="创建签到任务"
                android:textColor="@color/notion_card"
                app:backgroundTint="@color/cc_primary"
                app:cornerRadius="@dimen/radius_md" />
        </LinearLayout>

        <TextView
            android:id="@+id/textStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_lg"
            android:background="@drawable/bg_card"
            android:padding="@dimen/space_lg"
            android:textColor="@color/notion_body"
            android:textSize="13sp" />
    </LinearLayout>
</ScrollView>
