<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/notion_bg"
    android:orientation="vertical"
    android:padding="@dimen/space_xl">

    <TextView
        android:id="@+id/buttonBack"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="← Student"
        android:textColor="@color/notion_purple"
        android:textSize="15sp"
        android:textStyle="bold" />

    <TextView
        style="@style/NotionLabel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_xl"
        android:text="QR CHECK-IN" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_md"
        android:text="扫码签到."
        android:textColor="@color/notion_ink"
        android:textSize="38sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_lg"
        android:background="@drawable/bg_card"
        android:orientation="vertical"
        android:padding="@dimen/space_xl">

        <TextView
            android:id="@+id/textStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="请扫描教师端展示的签到二维码"
            android:textColor="@color/notion_body"
            android:textSize="15sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonScan"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:layout_marginTop="@dimen/space_lg"
            android:text="重新扫码"
            android:textColor="@color/notion_card"
            app:backgroundTint="@color/cc_primary"
            app:cornerRadius="@dimen/radius_md" />
    </LinearLayout>
</LinearLayout>



