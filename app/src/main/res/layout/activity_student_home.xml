<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/vc_bg"
    android:orientation="vertical"
    android:padding="@dimen/space_xl">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:background="@drawable/bg_button_primary"
            android:gravity="center"
            android:text="C"
            android:textColor="@color/vc_card"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_md"
            android:layout_weight="1"
            android:text="智课签"
            android:textColor="@color/vc_ink"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/buttonProfile"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_avatar_button"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="我"
            android:textColor="@color/vc_card"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        style="@style/VercelMonoLabel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_xl"
        android:text="STUDENT DASHBOARD" />

    <TextView
        android:id="@+id/textGreeting"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_sm"
        android:lineSpacingMultiplier="1.0"
        android:textColor="@color/vc_ink"
        android:textSize="32sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/textSummary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_sm"
        android:textColor="@color/vc_body"
        android:textSize="14sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_lg"
        android:background="@drawable/bg_navy_card"
        android:orientation="vertical"
        android:padding="@dimen/space_xl">

        <TextView
            style="@style/VercelMonoLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="LIVE CHECK-IN" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_lg"
            android:text="Android应用开发"
            android:textColor="@color/vc_card"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textHomeStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_md"
            android:textColor="@color/vc_mute"
            android:textSize="13sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonRecords"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="@dimen/space_lg"
            android:text="签到记录"
            android:textColor="@color/vc_ink"
            app:backgroundTint="@color/vc_card"
            app:cornerRadius="999dp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_marginTop="@dimen/space_lg"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonSchedule"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="周课表"
            android:textColor="@color/vc_ink"
            app:backgroundTint="@color/vc_card"
            app:cornerRadius="@dimen/radius_md"
            app:strokeColor="@color/vc_line"
            app:strokeWidth="1dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="@dimen/space_sm"
            android:layout_weight="1"
            android:background="@drawable/bg_card"
            android:gravity="center"
            android:text="92%\n出勤率"
            android:textColor="@color/vc_blue"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_lg"
        android:text="Courses"
        android:textColor="@color/vc_ink"
        android:textSize="20sp"
        android:textStyle="bold" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerCourses"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/space_md"
        android:layout_weight="1" />
</LinearLayout>
