<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.CampusCheckin" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:fontFamily">sans</item>
        <item name="colorPrimary">@color/vc_ink</item>
        <item name="colorPrimaryDark">@color/vc_ink</item>
        <item name="colorAccent">@color/vc_blue</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:statusBarColor">@color/vc_bg</item>
        <item name="android:navigationBarColor">@color/vc_bg</item>
        <item name="android:windowBackground">@color/vc_bg</item>
    </style>

    <style name="Theme.CampusCheckin" parent="Base.Theme.CampusCheckin" />

    <style name="StatNumber">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">52dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">@color/vc_ink</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="VercelMonoLabel">
        <item name="android:fontFamily">monospace</item>
        <item name="android:textColor">@color/vc_mute</item>
        <item name="android:textSize">12sp</item>
    </style>
</resources>
